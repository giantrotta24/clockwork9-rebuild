---
/*
  Lazy Vimeo facade: renders the video's real poster at build time and only
  loads the player iframe on interaction. This is the fix for the old site's
  LCP story (the hero player was the 8.1s LCP element) — the poster is a
  static, optimizable image; player JS costs nothing until requested.
*/
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
const playerSrc = `https://player.vimeo.com/video/${id}?color=F26739&title=0&byline=0&portrait=0&autoplay=1`;

let poster: string | null = null;
let width = 1280;
let height = 720;
try {
  const res = await fetch(
    `https://vimeo.com/api/oembed.json?url=${encodeURIComponent(`https://vimeo.com/${id}`)}&width=1280`
  );
  if (res.ok) {
    const data = await res.json();
    poster = (data.thumbnail_url as string | undefined) ?? null;
    if (data.width && data.height) {
      width = data.width;
      height = data.height;
    }
  }
} catch {
  /* offline build — facade falls back to a flat panel; player still works */
}
---

<div class="vimeo-facade" data-player-src={playerSrc} data-title={title} style={`aspect-ratio:${width}/${height}`}>
  <button class="vimeo-play" type="button">
    {poster && <img src={poster} alt="" loading="lazy" decoding="async" />}
    <span class="vimeo-play-badge" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
    </span>
    <span class="sr-only">Play video: {title}</span>
  </button>
  <noscript>
    <a href={`https://vimeo.com/${id}`}>Watch “{title}” on Vimeo</a>
  </noscript>
</div>

<style>
  .vimeo-facade {
    position: relative;
    width: 100%;
    background: #000;
    border-radius: 10px;
    overflow: hidden;
  }
  .vimeo-play {
    position: absolute;
    inset: 0;
    width: 100%;
    display: block;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
  }
  .vimeo-play img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .vimeo-play-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 74px;
    height: 74px;
    border-radius: 999px;
    background: rgba(16, 16, 15, 0.72);
    border: 1.5px solid var(--color-c9-cream);
    color: var(--color-c9-cream);
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .vimeo-play:hover .vimeo-play-badge {
    color: var(--color-c9-orange);
    border-color: var(--color-c9-orange);
  }
  .vimeo-facade iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .vimeo-facade noscript a { color: var(--color-c9-cream); }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.vimeo-facade').forEach((facade) => {
    const btn = facade.querySelector('.vimeo-play');
    btn?.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.src = facade.dataset.playerSrc ?? '';
      iframe.title = facade.dataset.title ?? 'Video';
      iframe.allow = 'autoplay; fullscreen; picture-in-picture';
      iframe.setAttribute('allowfullscreen', '');
      facade.replaceChildren(iframe);
      iframe.focus();
    });
  });
</script>
