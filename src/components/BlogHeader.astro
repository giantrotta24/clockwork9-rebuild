---
interface Props {
  active: string; // 'all' or a category slug
}
const { active } = Astro.props;

const categories = [
  { slug: 'all', label: 'All', href: '/blog/' },
  { slug: 'creative', label: 'Creative', href: '/blog/category/creative/' },
  { slug: 'marketing', label: 'Marketing', href: '/blog/category/marketing/' },
  { slug: 'news', label: 'News', href: '/blog/category/news/' },
  { slug: 'press', label: 'Press', href: '/blog/category/press/' },
  { slug: 'product-reviews', label: 'Product Reviews', href: '/blog/category/product-reviews/' },
  { slug: 'tutorials', label: 'Tutorials', href: '/blog/category/tutorials/' },
];
---

<section class="blog-header">
  <h1 class="display display-grad">Blog</h1>
  <p class="blog-subtitle">Insights, tips, and stories from the world of video production</p>
</section>

<nav class="category-nav" aria-label="Blog categories">
  {categories.map(({ slug, label, href }) => (
    <a href={href} class:list={['category-link', { active: slug === active }]} aria-current={slug === active ? 'page' : undefined}>
      {label}
    </a>
  ))}
</nav>

<style>
  .blog-header {
    text-align: center;
    padding: clamp(3rem, 7vw, 5.5rem) 1.5rem 0;
  }
  .blog-header h1 {
    font-size: clamp(2.4rem, 5.4vw, 4.4rem);
    text-transform: lowercase;
  }
  .blog-subtitle {
    font-style: italic;
    color: var(--ink-muted);
    margin-top: 1rem;
  }

  .category-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem;
    padding: 2.2rem 1.5rem 0;
  }
  .category-link {
    font-family: var(--font-label);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-c9-cream);
    text-decoration: none;
    border: 1.5px solid var(--color-c9-line);
    border-radius: 999px;
    padding: 0.45rem 1.1rem;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .category-link:hover { border-color: var(--color-c9-orange); color: var(--color-c9-orange); }
  .category-link.active {
    border-color: var(--color-c9-orange);
    color: var(--color-c9-orange);
  }
</style>
